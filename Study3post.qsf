ay":"A great deal"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText","TextPosition":"inline"},"DataExportTag":"i","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":4,"NextChoiceId":9,"QuestionDescription":"How much insight does this lesson give you?","QuestionID":"QID30","QuestionText":"How much insight does this lesson give you?","QuestionText_Unsafe":"How much insight does this lesson give you?","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}}}},{"SurveyID":"SV_01FfkwOhO3T3dOK","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"How useful is this lesson to you?","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2","3","4","5","6","7"],"Choices":{"1":{"Display":"Completely useless"},"2":{"Display":"Almost useless"},"3":{"Display":"A little useful"},"4":{"Display":"Somewhat useful"},"5":{"Display":"Moderately useful"},"6":{"Display":"Very useful"},"7":{"Display":"Extremely useful"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"u","DataVisibility":{"Hidden":false,"Private":false},"Language":[],"NextAnswerId":1,"NextChoiceId":8,"QuestionDescription":"How useful is this lesson to you?","QuestionID":"QID31","QuestionText":"How useful is this lesson to you?","QuestionText_Unsafe":"How useful is this lesson to you?","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}}}},{"SurveyID":"SV_01FfkwOhO3T3dOK","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"How valuable is this lesson to you?","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["2","3","4","5","7","8","9"],"Choices":{"2":{"Display":"Not valuable at all"},"3":{"Display":"Of almost no value"},"4":{"Display":"A little valuable"},"5":{"Display":"Some