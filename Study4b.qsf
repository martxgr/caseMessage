ibrary":"yalesurvey","SkinType":"templated","Skin":{"brandingId":"8974915071","templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","EOSMessage":null,"ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"No","RefererCheck":"No","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":"https:\/\/app.prolific.com\/submissions\/complete?cc=C10OZW7Z","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":null,"PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"SurveyName":"Study 3b (When Case Studies Promote Illusory Insights)"}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":false,"ID":"Survey Statistics"}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","IncludeDescription":"OFF"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please review what you originally read.<br><\/i><br>A company named VanMoof reported that more than 25 percent of its bikes were damaged before even being delivered. \"Your covetable products, your frictionless website, your killer brand\u200a\u2014\u200athey all count for nothing when your delivery partner drops the ball,\" said Bex Rad, Vanmoof's creative director.<br><br>The solution? Reconsider the packaging. \"We asked ourselves, what do Americans really love? What would prompt couriers to be delicate with a parcel?\" VanMoof co-founder Taco Carlier said.<br><br>A TV was the obvious answer.\n\nA big-screen TV box is roughly the same size and weight as a bike box. So to convince shippers to handle its products with more care, VanMoof began printing photos of TVs on its packaging. The boxes still depicted the bike, too, but at a glance it does look like you would find a massive widescreen TV inside instead of a high-end commuter bike.<br><br>Damages dropped by 80 percent since then, according to the company. Even after a reporter revealed the trick, the drop in damages has stayed consistent.<br>","DataExportTag":"relevant","QuestionID":"QID56","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \/\/ Define URL of the CSV file\n    var csvUrl = \"https:\/\/drive.google.com\/file\/d\/1OC7bT0HdR3O3TPw_YkXXw_3xG-IO_OOI\/view?usp=drive_link\";\n\n    \/\/ Fetch the CSV file\n    Papa.parse(csvUrl, {\n        download: true,\n        header: true,\n        complete: function(results) {\n            \/\/ Get the array of rows from the CSV file\n            var rows = results.data;\n\n            \/\/ Randomly select a row\n            var randomRowIndex = Math.floor(Math.random() * rows.length);\n            var randomRow = rows[randomRowIndex];\n\n            \/\/ Extract the text from the selected row (assuming there's only one column)\n            var text = randomRow[Object.keys(randomRow)[0]];\n\n            \/\/ Set the embedded data field with the extracted text\n            Qualtrics.SurveyEngine.setEmbeddedData(\"dynamicText\", text);\n        }\n    });\n});","Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv"}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"SQ","PrimaryAttribute":"QID211","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"message","QuestionID":"QID211","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv"}},{"SurveyID":"SV_bs9iO73rCNapKB0","Element":"SQ","PrimaryAttribute":"QID221","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","QuestionJS":false,"DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":