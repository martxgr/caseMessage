tion":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":0,"SnapToGrid":false,"NumDecimals":"0","ShowValue":false,"CustomStart":true,"SliderStartPositions":{"1":0.4981167608286252157512308258446864783763885498046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Now to what extent would you be able to apply the knowledge offered above to other situations?","Choices":{"1":{"Display":"~"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":3,"Labels":{"1":{"Display":"Not at all"},"2":{"Display":"Very much so"}},"QuestionID":"QID37"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID44","SecondaryAttribute":"Now to what extent would you be able to apply the knowledge offered above to other situations?","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Now to what extent would you be able to apply the knowledge offered above to other situations?<\/i>","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":0,"SnapToGrid":false,"NumDecimals":"0","ShowValue":false,"CustomStart":true,"SliderStartPositions":{"1":0.4981167608286252157512308258446864783763885498046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Now to what extent would you be able to apply the knowledge offered above to other situations?","Choices":{"1":{"Display":"~"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":3,"Labels":{"1":{"Display":"Not at all"},"2":{"Display":"Very much so"}},"QuestionText_Unsafe":"Now to what extent would you be able to apply the knowledge offered above to other situations?","DataExportTag":"a.g2","QuestionID":"QID44"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID1717912195","SecondaryAttribute":"Now, let's consider the other extreme. Try to remember one of the worst lessons you've ever recei...","TertiaryAttribute":null,"Payload":{"QuestionText":"Now, let's consider the other extreme. <br><br>Try to remember one of the <i>worst lessons<\/i> you've ever received -- again it could be from an article, video, class, or relative. Whatever you were taught could have even seemed interesting, but turned out to be totally empty or meaningless. This kind of lesson should get a \"None\" on the scale below.&nbsp;Please fill out the scale accordingly.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Now, let's consider the other extreme. Try to remember one of the worst lessons you've ever recei...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Now, let's consider the other extreme. <br><br>Try to remember one of the <i>worst lessons<\/i> you've ever received -- again it could be from an article, video, class, or relative. Whatever you were taught could have even seemed interesting, but turned out to be totally empty or meaningless. This kind of lesson should get a \"None\" on the scale below.&nbsp;Please fill out the scale accordingly.<br>","DataExportTag":"Q4","QuestionID":"QID1717912195"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID125","SecondaryAttribute":"Now, please rate the bolded information above.","TertiaryAttribute":null,"Payload":{"QuestionText":"Now, please rate the bolded information above.","DefaultChoices":false,"DataExportTag":"Q125","QuestionID":"QID125","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Now, please rate the bolded information above.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID75","SecondaryAttribute":"Overall, which statement do you find more insightful?","TertiaryAttribute":null,"Payload":{"QuestionText":"Overall, which statement do you find more insightful?","DefaultChoices":false,"DataExportTag":"choice","QuestionID":"QID75","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Overall, which statement do you find more insightful?","Choices":{"4":{"Display":"In 2000, Blockbuster had a chance to buy Netflix but thought the rival company\u2019s market was laughably niche. Come 2011, Netflix was worth 13 billion, and because of their decision, Blockbuster was bankrupt."},"5":{"Display":"Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit."}},"ChoiceOrder":["4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"Randomization":{"Advanced":null,"Type":"All","TotalRandSubset":""}}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"Please enter your unique prolific ID below","TertiaryAttribute":null,"Payload":{"QuestionText":"Please enter your unique prolific ID below","DefaultChoices":false,"DataExportTag":"id","QuestionID":"QID38","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please enter your unique prolific ID below","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"Please explain what additional information is provided by the statement chose (in comparison to t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please explain what additional information is provided by the statement chose (in comparison to the other).","DefaultChoices":false,"DataExportTag":"qual","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please explain what additional information is provided by the statement chose (in comparison to t...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"MinChar","MinChars":"6"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID33"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID1717485714","SecondaryAttribute":"Please give your age below (in years)","TertiaryAttribute":null,"Payload":{"QuestionText":"Please give your age below (in years)","DefaultChoices":false,"QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please give your age below (in years)","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","TotalChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"18","Max":"120","NumDecimals":"0"}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"Please give your age below (in years)","DataExportTag":"Q1","QuestionID":"QID1717485714"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID191","SecondaryAttribute":"Please now rate ALL of the information provided.","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Please now rate ALL of the information provided.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please now rate ALL of the information provided.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"The professor went on to state that the message of this case was:<br><br>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<br>","DataExportTag":"Q191","QuestionID":"QID191"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID201","SecondaryAttribute":"Please now rate ALL of the information provided.","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Please now rate ALL of the information provided.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please now rate ALL of the information provided.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Please rate the following just on the message again (the blue text). You are welcome to give the same answers or change them as you see fit.","DataExportTag":"Q201","QuestionID":"QID201"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID192","SecondaryAttribute":"Please rate the following just based on the message (the blue text).","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the following just based on the message (the blue text).","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please rate the following just based on the message (the blue text).","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Please rate the following just based on the message (the blue text).","DataExportTag":"Q192","QuestionID":"QID192"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID144","SecondaryAttribute":"Please rate this case again. You are welcome to give the same answers or change them as you see fit.","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Please rate this case again. You are welcome to give the same answers or change them as you see fit.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please rate this case again. You are welcome to give the same answers or change them as you see fit.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Please rate the following just based on the message (the blue text).","DataExportTag":"Q144","QuestionID":"QID144"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID177","SecondaryAttribute":"Please rate this message again. You are welcome to give the same answers or change them as you se...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Please rate this message again. You are welcome to give the same answers or change them as you see fit.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please rate this message again. You are welcome to give the same answers or change them as you se...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Please rate the following just on the message again (the blue text). You are welcome to give the same answers or change them as you see fit.","DataExportTag":"Q177","QuestionID":"QID177"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID124","SecondaryAttribute":"Please read the following information about something that actually happened involving the use of...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please read the following information about something that actually happened involving the use of Artificial Intelligence (AI) :<\/i><br><br>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>The company asked a cutting edge Artificial Intelligence what to do and it came up with a solution: the A.I. suggested that the company print a graphic of a flatscreen television on the side of the box. By following the AI's suggestion and making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.","DefaultChoices":false,"DataExportTag":"Q124","QuestionID":"QID124","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read the following information about something that actually happened involving the use of...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Please read the following: Companies that package their products in boxes that superficially rese...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please read the following:<\/i><br><br>Companies that package their products in boxes that superficially resemble those of products that shipping companies treat with care report lower damages and costs due to shipping.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read the following: Companies that package their products in boxes that superficially rese...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Companies and corporations that package their products in boxes that superficially resemble those of more fragile products reduce damages and costs due to shipping.","DataExportTag":"Q39","QuestionID":"QID39"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID77","SecondaryAttribute":"Please read the following: Companies, corporations, or industries that do not have the foresight...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please read the following:<br><\/i><br>Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read the following: Companies, corporations, or industries that do not have the foresight...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please read the following:<br><\/i><br>Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit.<br>","DataExportTag":"Q77","QuestionID":"QID77"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"Please review what you originally read. A company named VanMoof reported that more than 25 percen...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please review what you originally read.<br><\/i><br>A company named VanMoof reported that more than 25 percent of its bikes were damaged before even being delivered. \"Your covetable products, your frictionless website, your killer brand\u200a\u2014\u200athey all count for nothing when your delivery partner drops the ball,\" said Bex Rad, Vanmoof's creative director.<br><br>The solution? Reconsider the packaging. \"We asked ourselves, what do Americans really love? What would prompt couriers to be delicate with a parcel?\" VanMoof co-founder Taco Carlier said.<br><br>A TV was the obvious answer.\n\nA big-screen TV box is roughly the same size and weight as a bike box. So to convince shippers to handle its products with more care, VanMoof began printing photos of TVs on its packaging. The boxes still depicted the bike, too, but at a glance it does look like you would find a massive widescreen TV inside instead of a high-end commuter bike.<br><br>Damages dropped by 80 percent since then, according to the company. Even after a reporter revealed the trick, the drop in damages has stayed consistent.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please review what you originally read. A company named VanMoof reported that more than 25 percen...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please read the following:<\/i><br><br>A company named VanMoof reported that more than 25 percent of its bikes were damaged before even being delivered. \"Your covetable products, your frictionless website, your killer brand\u200a\u2014\u200athey all count for nothing when your delivery partner drops the ball,\" said Bex Rad, Vanmoof's creative director.<br><br>The solution? Reconsider the packaging. \"We asked ourselves, what do Americans really love? What would prompt couriers to be delicate with a parcel?\" VanMoof co-founder Taco Carlier said.<br><br>A TV was the obvious answer.\n\nA big-screen TV box is roughly the same size and weight as a bike box. So to convince shippers to handle its products with more care, VanMoof began printing photos of TVs on its packaging. The boxes still depicted the bike, too, but at a glance it does look like you would find a massive widescreen TV inside instead of a high-end commuter bike.<br><br>Damages dropped by 80 percent since then, according to the company. Even after a reporter revealed the trick, the drop in damages has stayed consistent.<br>","DataExportTag":"Q51","QuestionID":"QID51"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"Please review what you originally read: Companies that package their products in boxes that super...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please review what you originally read:<\/i><br><br>Companies that package their products in boxes that superficially resemble those of products that shipping companies treat with care report lower damages and costs due to shipping.<br>","DefaultChoices":false,"DataExportTag":"Q45","QuestionID":"QID45","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please review what you originally read: Companies that package their products in boxes that super...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID61","SecondaryAttribute":"Please review what you originally read: Companies that package their products in boxes that super...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please review what you originally read:<br><\/i><br>Companies that package their products in boxes that superficially resemble those of more fragile products reduce damages due to shipping.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please review what you originally read: Companies that package their products in boxes that super...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please read the following:<br><\/i><br>Companies that package their products in boxes that superficially resemble those of more fragile products reduce damages due to shipping.<br>","DataExportTag":"Q61","QuestionID":"QID61"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"Please select the middle option","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Please select the middle option<\/i><br>","DataExportTag":"att.n","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{