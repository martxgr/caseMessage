pe":"Question","QuestionID":"QID54"},{"Type":"Question","QuestionID":"QID55"},{"Type":"Question","QuestionID":"QID49"},{"Type":"Question","QuestionID":"QID47"},{"Type":"Question","QuestionID":"QID50"},{"Type":"Question","QuestionID":"QID15"},{"Type":"Question","QuestionID":"QID65"},{"Type":"Question","QuestionID":"QID64"},{"Type":"Question","QuestionID":"QID63"},{"Type":"Question","QuestionID":"QID62"},{"Type":"Question","QuestionID":"QID83"},{"Type":"Question","QuestionID":"QID68"},{"Type":"Question","QuestionID":"QID125"},{"Type":"Question","QuestionID":"QID131"},{"Type":"Question","QuestionID":"QID114"},{"Type":"Question","QuestionID":"QID145"},{"Type":"Question","QuestionID":"QID188"},{"Type":"Question","QuestionID":"QID186"},{"Type":"Question","QuestionID":"QID184"},{"Type":"Question","QuestionID":"QID158"},{"Type":"Question","QuestionID":"QID174"},{"Type":"Question","QuestionID":"QID200"},{"Type":"Question","QuestionID":"QID192"},{"Type":"Question","QuestionID":"QID198"},{"Type":"Question","QuestionID":"QID207"},{"Type":"Question","QuestionID":"QID127"},{"Type":"Question","QuestionID":"QID143"},{"Type":"Question","QuestionID":"QID176"},{"Type":"Question","QuestionID":"QID217"}]},"6":{"Type":"Standard","Description":"keil: consent","ID":"BL_8xp71VC5mZj5Z42","BlockElements":[{"Type":"Question","QuestionID":"QID1717457503"},{"Type":"Question","QuestionID":"QID1717457504","SkipLogic":[{"SkipLogicID":1,"ChoiceLocator":"q:\/\/QID1717457504\/SelectableChoice\/2","Condition":"Selected","SkipToDestination":"ENDOFSURVEY","Locator":"q:\/\/QID1717457504\/SelectableChoice\/2","SkipToDescription":"Do you consent to participa... <strong>No<\/strong>  <strong>Is Selected<\/strong>","Description":"Condition: <strong title=\"No\">No<\/strong> <strong>Is Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","QuestionID":"QID1717457504"}]},{"Type":"Question","QuestionID":"QID38"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"false","BlockVisibility":"Collapsed"}},"13":{"Type":"Standard","SubType":"","Description":"case vienna","ID":"BL_cvbYzHUQA9GUQw6","BlockElements":[{"Type":"Question","QuestionID":"QID129"},{"Type":"Question","QuestionID":"QID56"},{"Type":"Question","QuestionID":"QID218"},{"Type":"Question","QuestionID":"QID57"},{"Type":"Question","QuestionID":"QID58"},{"Type":"Question","QuestionID":"QID59"},{"Type":"Question","QuestionID":"QID60"},{"Type":"Question","QuestionID":"QID98"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"Advanced","Randomization":{"Advanced":{"FixedOrder":["QID129","QID56","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["QID57","QID58","QID59","QID60","QID98","QID218"],"RandomSubSet":[],"Undisplayed":[],"TotalRandSubset":0,"QuestionsPerPage":0},"EvenPresentation":false},"BlockVisibility":"Expanded","Looping":"Static","LoopingOptions":{"Static":{"1":{"1":"Importance of washing hands especially in hospitals etc "},"2":{"1":"i learned that it takes time to prove something that is happening now , and you should have evidence of your findings or else people won't believe you "},"3":{"1":"Doctors wash their hands before surgery to remove any dirt, germs, or bacteria that could cause infections. This helps ensure a sterile environment and reduces the risk of complications for the patient."},"4":{"1":"i learnt about the adaptation of doctors washing hands. it was very interesting to note that doctor did not or barely washed hands in the past"},"5":{"1":"I learned that you should always listen to what people have to say"},"6":{"1":"I learnt that it is important for doctors to wash their hands before assisting patients to avoid spread of illnesses"},"7":{"1":"I learned how important it is to be mindful of germs around you. Whether from the environment, surfaces or people"},"8":{"1":"i learned that washing your hands is very important, of course i always knew this but finding out the impact of it and the number of deaths is quite alarming"},"9":{"1":"The importance of hand washing especially in medical settings. Germs are very dangerous, and can cause further medical complications and cross contamination."},"10":{"1":"I already knew this case but it was helpful to be reminded of it"}},"Randomization":"Subset","TotalRandSubset":"1"}}},"29":{"Type":"Standard","SubType":"","Description":"message vienna","ID":"BL_0VxvpfNdVJZB9Hg","BlockElements":[{"Type":"Question","QuestionID":"QID210"},{"Type":"Question","QuestionID":"QID211"},{"Type":"Question","QuestionID":"QID219"},{"Type":"Question","QuestionID":"QID212"},{"Type":"Question","QuestionID":"QID213"},{"Type":"Question","QuestionID":"QID214"},{"Type":"Question","QuestionID":"QID215"},{"Type":"Question","QuestionID":"QID216"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"Advanced","Randomization":{"Advanced":{"FixedOrder":["QID210","QID211","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["QID212","QID213","QID214","QID215","QID216","QID219"],"RandomSubSet":[],"Undisplayed":[],"TotalRandSubset":0,"QuestionsPerPage":0},"EvenPresentation":false},"BlockVisibility":"Expanded","Looping":"Static","LoopingOptions":{"Static":{"1":{"1":"I've learnt that, very often, despite the presence of indisputable evidence, people need underlying theories to accept this point of view."},"2":{"1":"I learned that no matter how much you speak to someone about an idea\/theory, they will be less inclined to change their mind or believe you without showing them evidence. Seeing is believing for most people"},"3":{"1":"proof is required to change someone's mind"},"4":{"1":"How to try to understand the perspective of others based on the the theory they support"},"5":{"1":"Even if there is evidence, some people will need something more than that to convince themselves "},"6":{"1":"I learned that in order to make a new argument or present some kind of new information to an audience, it must be supported by some kind of underlying theory or information in order for someone to be more likely to consider and accept it as factual information to be used in everyday life."},"7":{"1":"The lesson is that to make something believable, you need more than just evidence because what you also need is an underlying theory to tie it all. I tend to disagree because it is theories that require evidence to make them compelling. Evidence, however, can tell the story they need without assistance. Concrete evidence can not be denied because it is factual and objective."},"8":{"1":"We should change our mindsets"},"9":{"1":"I learned that even if u gather any sort of types of evidence, you basically need a good argument and theory to explain why such evidence is relevant, you can't just have something to show without explaining why it is that what you're showing is important."},"10":{"1":"I wouldnt be swayed by underlying support or need reinforcement if data provided is irrefutable. "}},"Randomization":"Subset","TotalRandSubset":"1"}}},"30":{"Type":"Standard","SubType":"","Description":"case dominos","ID":"BL_czJd0nGhjkFTKp8","BlockElements":[{"Type":"Question","QuestionID":"QID220"},{"Type":"Question","QuestionID":"QID221"},{"Type":"Question","QuestionID":"QID222"},{"Type":"Question","QuestionID":"QID223"},{"Type":"Question","QuestionID":"QID224"},{"Type":"Question","QuestionID":"QID225"},{"Type":"Question","QuestionID":"QID226"},{"Type":"Question","QuestionID":"QID227"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"Advanced","Randomization":{"Advanced":{"FixedOrder":["QID220","QID221","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["QID223","QID224","QID225","QID226","QID227","QID222"],"RandomSubSet":[],"Undisplayed":[],"TotalRandSubset":0,"QuestionsPerPage":0},"EvenPresentation":false},"BlockVisibility":"Expanded","Looping":"Static","LoopingOptions":{"Static":{"1":{"1":"I learned that optimising delivery processes can increase conversion rate, but I didn't learn specifically what they did or get any wider competitior\/market context"},"2":{"1":"They didn\u2019t try to fix the actual product (low quality pizza) but tried to make better the customer service\/experience"},"3":{"1":"I have learned the importance of using technology to improve your sales."},"4":{"1":"I guess I learned that the dominos share price increased over that period, but there wasn't enough information to really conclude it was due to what they did on sales systems. There wasn't much cause and effect explanation or proper insight into the business model and profitability or growth.. "},"5":{"1":"The customer not always expect that the company solve their problem. Sometimes innovation may outcome their satisfaction versus their current level of dissatisfaction."},"6":{"1":"Sometimes you need to think outside of the box in order to improve your business. You might be struggling because your product is bad, but if you find a new way to distribute it, often times people will be curious about the changes and will continue to buy from you."},"7":{"1":"instead of improving quality which would be more costly, Dominos gave customers more control (or the feeling of) their customer experience "},"8":{"1":"I learned that Dominos increased their value not through improving their pizzas but instead by increasing the accessibility of their pizzas even though their popularity was poor, this enabled customers to customise their pizzas on the app and made the process more smooth."},"9":{"1":"That a change is not always a correct answer."},"10":{"1":"This lesson or case study is woefully short of information, detail and context.  In the most basic sense, I guess there is a business lesson that if you cant\/wont focus on improving a mediocre quality product, becoming best in class re logistics, technology to access and customer customisation may be a substitute strategy to win back market share, but where is the info on how this was achieved - what tech improvements looked like, how customer appetite for online ordering evolved(trends etc), what was the messaging to customers looking like (and what were the measurements) to underpin the counterintuitive expectation that a struggling brand with a poor product could possibly succeed to this level?  Also info on competition, how did they manage to win here? Versus not just other pizza makers but other fast food - what was going in in the market to allow this slingshot of sales growth to prosper?  Next to useless without 100 times more detail!"}},"Randomization":"Subset","TotalRandSubset":"1"}}},"31":{"Type":"Standard","SubType":"","Description":"message dominos","ID":"BL_89eofa2kkpuokBw","BlockElements":[{"Type":"Question","QuestionID":"QID228"},{"Type":"Question","QuestionID":"QID229"},{"Type":"Question","QuestionID":"QID230"},{"Type":"Question","QuestionID":"QID231"},{"Type":"Question","QuestionID":"QID232"},{"Type":"Question","QuestionID":"QID233"},{"Type":"Question","QuestionID":"QID234"},{"Type":"Question","QuestionID":"QID235"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"Advanced","Randomization":{"Advanced":{"FixedOrder":["QID228","QID229","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["QID231","QID232","QID233","QID234","QID235","QID230"],"RandomSubSet":[],"Undisplayed":[],"TotalRandSubset":0,"QuestionsPerPage":0},"EvenPresentation":false},"BlockVisibility":"Expanded","Looping":"Static","LoopingOptions":{"Static":{"1":{"1":"If we deliver a fast and easy delivery process to the customer, their perception about the product may improve, even though the product itself didn't improve."},"2":{"1":"I learned that as much as a product can be good or relate to a specific need, the importance of speedy easy delivery along with customer service the the key factors of a business these days and can make or break a business depending on price and speed of delivery."},"3":{"1":"As it was said, you don`t need to improve the product it helps, if you improve the delivery. A little example would help to gain more insight."},"4":{"1":"In short it said it is better to perfect the customer service and service delivery than the product itself."},"5":{"1":"This lesson taught me that somethings do not require change a little moderation here and there could go a long way"},"6":{"1":"Speed output is more valuable than quality of product"},"7":{"1":"sometimes the delivery speed is more important to focus on than the product itself"},"8":{"1":"As someone who has been exposed to more complex accounting matters, the principle that sometimes, is it more valuable for a company to be more efficient (reducing costs or increasing production without further investment), is absolutely correct. It can happen that the company has no more access to financing or that the market in which it operates is currently down. However, this statement is ver vague and it would need further explanation"},"9":{"1":"sometimes is better to improve the service that comes with the product (delivery) than the product itself"},"10":{"1":"We should not delay in readily delivering the product for the utmost convenience to the consumer, as opposed to bettering said product."}},"Randomization":"Subset","TotalRandSubset":"1"}}},"33":{"Type":"Standard","SubType":"","Description":"case\/message anchoring module","ID":"BL_1YoBsfGiixZbRQy","BlockElements":[{"Type":"Question","QuestionID":"QID1717912192"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID1717912193"},{"Type":"Question","QuestionID":"QID1717912194","SkipLogic":[{"SkipLogicID":2,"ChoiceLocator":"q:\/\/QID1717912194\/SelectableChoice\/7","Condition":"NotSelected","SkipToDestination":"ENDOFSURVEY","Locator":"q:\/\/QID1717912194\/SelectableChoice\/7","SkipToDescription":"How much insight did that l... <strong>A great deal<\/strong>  <strong>Is Not Selected<\/strong>","Description":"Condition: <strong title=\"A great deal\">A great deal<\/strong> <strong>Is Not Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","QuestionID":"QID1717912194"}]},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID1717912195"},{"Type":"Question","QuestionID":"QID1717912196","SkipLogic":[{"SkipLogicID":3,"ChoiceLocator":"q:\/\/QID1717912196\/SelectableChoice\/1","Condition":"NotSelected","SkipToDestination":"ENDOFSURVEY","Locator":"q:\/\/QID1717912196\/SelectableChoice\/1","SkipToDescription":"How much insight did that l... <strong>None<\/strong>  <strong>Is Not Selected<\/strong>","Description":"Condition: <strong title=\"None\">None<\/strong> <strong>Is Not Selected<\/strong>. Skip To: <strong>End of Survey<\/strong>.","QuestionID":"QID1717912196"}]},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID1717912197"}],"Options":{"BlockLocking":false,"RandomizeQuestions":"false","BlockVisibility":"Expanded"}}}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Type":"Root","FlowID":"FL_1","Flow":[{"Type":"Standard","ID":"BL_8xp71VC5mZj5Z42","FlowID":"FL_2","Autofill":[]},{"Type":"Standard","ID":"BL_1YoBsfGiixZbRQy","FlowID":"FL_5","Autofill":[]},{"Type":"BlockRandomizer","FlowID":"FL_4","SubSet":1,"EvenPresentation":true,"Flow":[{"Type":"Block","ID":"BL_cvbYzHUQA9GUQw6","FlowID":"FL_6","Autofill":[]},{"Type":"Standard","ID":"BL_0VxvpfNdVJZB9Hg","FlowID":"FL_7","Autofill":[]},{"Type":"Standard","ID":"BL_czJd0nGhjkFTKp8","FlowID":"FL_8","Autofill":[]},{"Type":"Standard","ID":"BL_89eofa2kkpuokBw","FlowID":"FL_9","Autofill":[]}]}],"Properties":{"Count":9,"RemovedFieldsets":[]}}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"fa1852f5-96e1-4caf-b623-b8f9fb6be3e5"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"RS","PrimaryAttribute":"RS_d4HpQeJeZMZtr7w","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"Redirect","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"yalesurvey","SkinType":"templated","Skin":{"brandingId":"8974915071","templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","EOSMessage":null,"ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"No","RefererCheck":"No","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":"https:\/\/app.prolific.com\/submissions\/complete?cc=CWXOPOUY","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":null,"PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"SurveyName":"Study 2b (When Case Studies Promote Illusory Insights)"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","IncludeDescription":"OFF"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please review what you originally read.<br><\/i><br>A company named VanMoof reported that more than 25 percent of its bikes were damaged before even being delivered. \"Your covetable products, your frictionless website, your killer brand\u200a\u2014\u200athey all count for nothing when your delivery partner drops the ball,\" said Bex Rad, Vanmoof's creative director.<br><br>The solution? Reconsider the packaging. \"We asked ourselves, what do Americans really love? What would prompt couriers to be delicate with a parcel?\" VanMoof co-founder Taco Carlier said.<br><br>A TV was the obvious answer.\n\nA big-screen TV box is roughly the same size and weight as a bike box. So to convince shippers to handle its products with more care, VanMoof began printing photos of TVs on its packaging. The boxes still depicted the bike, too, but at a glance it does look like you would find a massive widescreen TV inside instead of a high-end commuter bike.<br><br>Damages dropped by 80 percent since then, according to the company. Even after a reporter revealed the trick, the drop in damages has stayed consistent.<br>","DataExportTag":"case","QuestionID":"QID56","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \/\/ Define URL of the CSV file\n    var csvUrl = \"https:\/\/drive.google.com\/file\/d\/1OC7bT0HdR3O3TPw_YkXXw_3xG-IO_OOI\/view?usp=drive_link\";\n\n    \/\/ Fetch the CSV file\n    Papa.parse(csvUrl, {\n        download: true,\n        header: true,\n        complete: function(results) {\n            \/\/ Get the array of rows from the CSV file\n            var rows = results.data;\n\n            \/\/ Randomly select a row\n            var randomRowIndex = Math.floor(Math.random() * rows.length);\n            var randomRow = rows[randomRowIndex];\n\n            \/\/ Extract the text from the selected row (assuming there's only one column)\n            var text = randomRow[Object.keys(randomRow)[0]];\n\n            \/\/ Set the embedded data field with the extracted text\n            Qualtrics.SurveyEngine.setEmbeddedData(\"dynamicText\", text);\n        }\n    });\n});","Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID211","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"message","QuestionID":"QID211","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID221","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","QuestionJS":false,"DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv","QuestionText_Unsafe":"<i>\"${lm:\/\/Field\/1}\"<\/i>","DataExportTag":"Q221","QuestionID":"QID221"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID229","SecondaryAttribute":"\"${lm:\/\/Field\/1}\"","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>\"${lm:\/\/Field\/1}\"<\/i>","QuestionJS":false,"DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\"${lm:\/\/Field\/1}\"","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"Files":"F_pdpFBFSr2jp2JAL","FilesDescription":"n.p13.text.csv","QuestionText_Unsafe":"<i>\"${lm:\/\/Field\/1}\"<\/i>","DataExportTag":"Q229","QuestionID":"QID229"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"241","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"A bike company decided to make their shipping boxes look like they held a television, which is re...","TertiaryAttribute":null,"Payload":{"QuestionText":"A bike company decided to make their shipping boxes look like they held a television, which is relatively fragile. This may have reduced damages due to shipping by 80%.","DefaultChoices":false,"DataExportTag":"sp.wwt","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"A bike company decided to make their shipping boxes look like they held a television, which is re...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"A bike company made their shipping boxes look like they contained a television, which is relative...","TertiaryAttribute":null,"Payload":{"QuestionText":"A bike company made their shipping boxes look like they contained a television, which is relatively fragile. In turn, damages caused by shipping were reduced by 80%.","DefaultChoices":false,"DataExportTag":"sd.wwt","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"A bike company made their shipping boxes look like they contained a television, which is relative...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID9"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID133","SecondaryAttribute":"After reading, please rate the following just based on the message (the blue text).","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>After reading, please rate the following just based on the message<\/b> (<span style=\"color:#2980b9;\"><i>the blue text<\/i><\/span>).","DefaultChoices":false,"DataExportTag":"Q133","QuestionID":"QID133","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"After reading, please rate the following just based on the message (the blue text).","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID161","SecondaryAttribute":"After reading, please rate the following just on the message again (the blue text). You are welco...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>After reading, please rate the following just on the message again<\/b> (<span style=\"color:#2980b9;\"><i>the blue text<\/i><\/span>). You are welcome to give the same answers or change them as you see fit.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"After reading, please rate the following just on the message again (the blue text). You are welco...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Please rate the following just based on the message (the blue text).","DataExportTag":"Q161","QuestionID":"QID161"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID129","SecondaryAttribute":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Again, in a previous study, we had participants review a business lesson and then summarize it in their own words. Please read and rate what they wrote.<\/b>","DefaultChoices":false,"DataExportTag":"Q129","QuestionID":"QID129","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID210","SecondaryAttribute":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Again, in a previous study, we had participants review a business lesson and then summarize it in their own words. Please read and rate what they wrote.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Please read the following information:<\/b><br>","DataExportTag":"Q210","QuestionID":"QID210","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \/\/ Define your list of items\n    var itemList = [\n        \"It made me realize i can influence the way people treat my packages by making them seem more fragile than they actually are\",\n        \"That packing carefully your items makes your shipping more safe so that it doesnt break anything\",\n        \"If you pack your delivery in a package resembling a fragile delivery, then it's more likely that your package won't be damaged because people will deal with it more carefully\",\n        \"Use more fragile materials to package the product\",\n        \"This is an easy way to save some money\",\n        \"I learned that packaging that portrays fragileness tends to have a less likelihood of being damaged\",\n        \"I learned that by making a package appear as fragile cargo I could make delivery companies more careful with my packages\",\n        \"I have taken from the lesson that because the packaging would give the impression of being fragile, it will be handled with better care, hence resulting in less damage to said products\",\n        \"Interesting information however limited. could have done with a little more information to make it really useful\",\n        \"I learnt by packaging something up to look like there is something fragile inside greater care is likely to be taken with the package\",\n        \"I learned that the way of package influence how much the products are safe\",\n        \"Packing products into boxes that resemble the ones used for transporting fragile cargo reduces the risk of damage during transportation\",\n        \"To make sure the product doesnt get damage during the transportation fase, companies use tactics such as labeling their goods as fragile in order for them to be treated carefully\",\n        \"Companies that sending stuff are using labels to avoid damages\",\n        \"Using a safer package could help you minimize losses in your business (probably because the product would be less likely to be damaged). This information could be useful if you are planning to start a business in which you plan to send a lot of packages. Otherwise, it doesn't seem that important\",\n        \"Learned about packaging of items in an appropriate way, making sure they are well protected so they won\u2019t get damaged easily and won\u2019t damage the way they are crated up for shipping, and so they can\u2019t damage the tire of haulage that are shipping them\",\n        \"I think that this kind of information is somewhat valuable, because even if I don't work in this kind of context, in some moment of my life I could use this information later in my life\"\n];\n\nvar randomIndex = Math.floor(Math.random() * itemList.length);\nQualtrics.SurveyEngine.setEmbeddedData(\"message\", itemList[randomIndex]);\n\t});"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID220","SecondaryAttribute":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Again, in a previous study, we had participants review a business lesson and then summarize it in their own words. Please read and rate what they wrote.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>In a previous study, we had participants review some information and then summarize it in their own words. Please read and rate what they wrote.<\/b>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \/\/ Define your list of items\n    var itemList = [\n        \"It made me realize i can influence the way people treat my packages by making them seem more fragile than they actually are\",\n        \"That packing carefully your items makes your shipping more safe so that it doesnt break anything\",\n        \"If you pack your delivery in a package resembling a fragile delivery, then it's more likely that your package won't be damaged because people will deal with it more carefully\",\n        \"Use more fragile materials to package the product\",\n        \"This is an easy way to save some money\",\n        \"I learned that packaging that portrays fragileness tends to have a less likelihood of being damaged\",\n        \"I learned that by making a package appear as fragile cargo I could make delivery companies more careful with my packages\",\n        \"I have taken from the lesson that because the packaging would give the impression of being fragile, it will be handled with better care, hence resulting in less damage to said products\",\n        \"Interesting information however limited. could have done with a little more information to make it really useful\",\n        \"I learnt by packaging something up to look like there is something fragile inside greater care is likely to be taken with the package\",\n        \"I learned that the way of package influence how much the products are safe\",\n        \"Packing products into boxes that resemble the ones used for transporting fragile cargo reduces the risk of damage during transportation\",\n        \"To make sure the product doesnt get damage during the transportation fase, companies use tactics such as labeling their goods as fragile in order for them to be treated carefully\",\n        \"Companies that sending stuff are using labels to avoid damages\",\n        \"Using a safer package could help you minimize losses in your business (probably because the product would be less likely to be damaged). This information could be useful if you are planning to start a business in which you plan to send a lot of packages. Otherwise, it doesn't seem that important\",\n        \"Learned about packaging of items in an appropriate way, making sure they are well protected so they won\u2019t get damaged easily and won\u2019t damage the way they are crated up for shipping, and so they can\u2019t damage the tire of haulage that are shipping them\",\n        \"I think that this kind of information is somewhat valuable, because even if I don't work in this kind of context, in some moment of my life I could use this information later in my life\"\n];\n\nvar randomIndex = Math.floor(Math.random() * itemList.length);\nQualtrics.SurveyEngine.setEmbeddedData(\"message\", itemList[randomIndex]);\n\t});","DataExportTag":"Q220","QuestionID":"QID220"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID228","SecondaryAttribute":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Again, in a previous study, we had participants review a business lesson and then summarize it in their own words. Please read and rate what they wrote.<\/b>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, in a previous study, we had participants review a business lesson and then summarize it in...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>In a previous study, we had participants review some information and then summarize it in their own words. Please read and rate what they wrote.<\/b>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \/\/ Define your list of items\n    var itemList = [\n        \"It made me realize i can influence the way people treat my packages by making them seem more fragile than they actually are\",\n        \"That packing carefully your items makes your shipping more safe so that it doesnt break anything\",\n        \"If you pack your delivery in a package resembling a fragile delivery, then it's more likely that your package won't be damaged because people will deal with it more carefully\",\n        \"Use more fragile materials to package the product\",\n        \"This is an easy way to save some money\",\n        \"I learned that packaging that portrays fragileness tends to have a less likelihood of being damaged\",\n        \"I learned that by making a package appear as fragile cargo I could make delivery companies more careful with my packages\",\n        \"I have taken from the lesson that because the packaging would give the impression of being fragile, it will be handled with better care, hence resulting in less damage to said products\",\n        \"Interesting information however limited. could have done with a little more information to make it really useful\",\n        \"I learnt by packaging something up to look like there is something fragile inside greater care is likely to be taken with the package\",\n        \"I learned that the way of package influence how much the products are safe\",\n        \"Packing products into boxes that resemble the ones used for transporting fragile cargo reduces the risk of damage during transportation\",\n        \"To make sure the product doesnt get damage during the transportation fase, companies use tactics such as labeling their goods as fragile in order for them to be treated carefully\",\n        \"Companies that sending stuff are using labels to avoid damages\",\n        \"Using a safer package could help you minimize losses in your business (probably because the product would be less likely to be damaged). This information could be useful if you are planning to start a business in which you plan to send a lot of packages. Otherwise, it doesn't seem that important\",\n        \"Learned about packaging of items in an appropriate way, making sure they are well protected so they won\u2019t get damaged easily and won\u2019t damage the way they are crated up for shipping, and so they can\u2019t damage the tire of haulage that are shipping them\",\n        \"I think that this kind of information is somewhat valuable, because even if I don't work in this kind of context, in some moment of my life I could use this information later in my life\"\n];\n\nvar randomIndex = Math.floor(Math.random() * itemList.length);\nQualtrics.SurveyEngine.setEmbeddedData(\"message\", itemList[randomIndex]);\n\t});","DataExportTag":"Q228","QuestionID":"QID228"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID1717912197","SecondaryAttribute":"Alright, onto the information we want you to rate!","TertiaryAttribute":null,"Payload":{"QuestionText":"Alright, onto the information we want you to rate!","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Alright, onto the information we want you to rate!","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Alright, onto the lesson!","DataExportTag":"Q6","QuestionID":"QID1717912197"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID96","SecondaryAttribute":"Business school professors studied the case you read and summarized it as follows: Companies that...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Business school professors studied the case you read and summarized it as follows:<\/i><br>\n<br>\n<strong>Companies that package their products in boxes that superficially resemble those of more fragile products may reduce damages due to shipping.<\/strong>","DefaultChoices":false,"DataExportTag":"Q96","QuestionID":"QID96","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Business school professors studied the case you read and summarized it as follows: Companies that...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID95","SecondaryAttribute":"Business school professors studied the case you were shown and summarized it as follows: Companie...","TertiaryAttribute":null,"Payload":{"QuestionText":"Business school professors studied the case you were shown and summarized it as follows:<br><br><i>Companies that package their products in boxes that superficially resemble those of more fragile products may reduce damages due to shipping.<\/i><br>","DefaultChoices":false,"QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Business school professors studied the case you were shown and summarized it as follows: Companie...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"MinChar","MinChars":"5"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"The information you were shown derives from this case study:<br><br>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.\n\nThe damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>&nbsp;The company came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found instantaneous results: shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<i><\/i><br><br>Please try to write anything the first thing you read taught you that the case study did not.<br>","DataExportTag":"Q95","QuestionID":"QID95"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID1717912192","SecondaryAttribute":"Business schools have been criticized for giving lessons of inconsistent quality. In a previous s...","TertiaryAttribute":null,"Payload":{"QuestionText":"Business schools have been criticized for giving lessons of inconsistent quality.<br><br>In a previous study, we had participants review a randomly selected lesson and then summarize it in their own words. <br><br>In this study, we would like you to read and rate what they wrote. It may be good; it may be bad; and it may be somewhere in between.<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Business schools have been criticized for giving lessons of inconsistent quality. In a previous s...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Business schools have been criticized for giving lessons of inconsistent quality. <br><br>So, we want your help in giving an accurate assessment of the quality of a randomly selected lesson. It may be good; it may be bad; and it may be somewhere in between.<br>","DataExportTag":"Q1","QuestionID":"QID1717912192"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID208","SecondaryAttribute":"By how much were VanMoof's shipping costs reduced after implementing the employee's solution?","TertiaryAttribute":null,"Payload":{"QuestionText":"By how much were VanMoof's shipping costs reduced after implementing the employee's solution?","DefaultChoices":false,"DataExportTag":"man","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"By how much were VanMoof's shipping costs reduced after implementing the employee's solution?","Choices":{"1":{"Display":"Virtually 0%: The solution did not work"},"2":{"Display":"50-60%"},"3":{"Display":"60-70%"},"4":{"Display":"70-80%"},"5":{"Display":"80-90%"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID208","Randomization":{"Advanced":null,"Type":"All","TotalRandSubset":""}}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID1"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q5","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_1SRJEJ9F6HEN2w6","Element":"SQ","PrimaryAttribute":"QID16","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q16","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":f