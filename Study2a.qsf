DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies and corporations that package their products in boxes that superficially resemble those...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID6"}},{"SurveyID":"SV_9SsLUX1YLBxRm6i","Element":"SQ","PrimaryAttribute":"QID152","SecondaryAttribute":"Companies that package their products in ways that superficially resemble those of more fragile p...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies that package their products in ways that superficially resemble those of more fragile p...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<br>","DataExportTag":"Q152","QuestionID":"QID152"}},{"SurveyID":"SV_9SsLUX1YLBxRm6i","Element":"SQ","PrimaryAttribute":"QID168","SecondaryAttribute":"Companies that package their products in ways that superficially resemble those of more fragile p...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies that package their products in ways that superficially resemble those of more fragile p...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.","DataExportTag":"Q168","QuestionID":"QID168"}},{"SurveyID":"SV_9SsLUX1YLBxRm6i","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","TertiaryAttribute":null,"Payload":{"QuestionText":"Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit.","DefaultChoices":false,"DataExportTag":"gd.bg","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID3"}},{"SurveyID