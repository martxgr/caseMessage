hoice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID805"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"Companies and corporations that package their products in boxes that superficially resemble those...","TertiaryAttribute":null,"Payload":{"QuestionText":"Companies and corporations that package their products in boxes that superficially resemble those of more fragile products may reduce damages and costs due to shipping.","DefaultChoices":false,"DataExportTag":"gp.wwt","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies and corporations that package their products in boxes that superficially resemble those...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID6"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID152","SecondaryAttribute":"Companies that package their products in ways that superficially resemble those of more fragile p...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies that package their products in ways that superficially resemble those of more fragile p...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<br>","DataExportTag":"Q152","QuestionID":"QID152"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID168","SecondaryAttribute":"Companies that package their products in ways that superficially resemble those of more fragile p...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies that package their products in ways that superficially resemble those of more fragile p...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.","DataExportTag":"Q168","QuestionID":"QID168"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","TertiaryAttribute":null,"Payload":{"QuestionText":"Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit.","DefaultChoices":false,"DataExportTag":"gd.bg","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID3"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","TertiaryAttribute":null,"Payload":{"QuestionText":"Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences may sometimes find themselves pushing outdated products and unable to turn a profit.","DefaultChoices":false,"DataExportTag":"gp.bg","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID7"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","TertiaryAttribute":null,"Payload":{"QuestionText":"Companies, corporations, or industries that do not have the foresight to anticipate future consumer desires and preferences will always find themselves pushing outdated products and unable to turn a profit.","DefaultChoices":false,"DataExportTag":"sd.bg","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Companies, corporations, or industries that do not have the foresight to anticipate future consum...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID10"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID1717457504","SecondaryAttribute":"Do you consent to participate in this research?","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you consent to participate in this research?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you consent to participate in this research?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"Do you consent to participate in this research?","DataExportTag":"consent","QuestionID":"QID1717457504"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"Dr. James Patel, a seasoned internist, was puzzled by the case of Mrs. Thompson, an elderly woman...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Dr. James Patel, a seasoned internist, was puzzled by the case of Mrs. Thompson, an elderly woman who had been experiencing chronic fatigue and intermittent chest pain. Despite numerous tests and consultations with specialists, no definitive diagnosis emerged. One afternoon, during a routine follow-up, Dr. Patel decided to sit down and thoroughly listen to Mrs. Thompson's story without interruption. As she described her symptoms in detail, she mentioned feeling a tightness in her chest after drinking her morning coffee, a seemingly minor detail previously overlooked. Dr. Patel realized that her symptoms pointed to a rare form of caffeine-induced angina. Further tests confirmed the diagnosis, and with lifestyle adjustments, Mrs. Thompson's condition improved. This case reinforced the importance of truly listening to patients, as they often provide the crucial clues needed for an accurate diagnosis.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dr. James Patel, a seasoned internist, was puzzled by the case of Mrs. Thompson, an elderly woman...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Please review what you originally read.<br><\/i><br>A company named VanMoof reported that more than 25 percent of its bikes were damaged before even being delivered. \"Your covetable products, your frictionless website, your killer brand\u200a\u2014\u200athey all count for nothing when your delivery partner drops the ball,\" said Bex Rad, Vanmoof's creative director.<br><br>The solution? Reconsider the packaging. \"We asked ourselves, what do Americans really love? What would prompt couriers to be delicate with a parcel?\" VanMoof co-founder Taco Carlier said.<br><br>A TV was the obvious answer.\n\nA big-screen TV box is roughly the same size and weight as a bike box. So to convince shippers to handle its products with more care, VanMoof began printing photos of TVs on its packaging. The boxes still depicted the bike, too, but at a glance it does look like you would find a massive widescreen TV inside instead of a high-end commuter bike.<br><br>Damages dropped by 80 percent since then, according to the company. Even after a reporter revealed the trick, the drop in damages has stayed consistent.<br>","DataExportTag":"Q56","QuestionID":"QID56"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID131","SecondaryAttribute":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to cus...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.","DefaultChoices":false,"DataExportTag":"Q131","QuestionID":"QID131","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to cus...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID135","SecondaryAttribute":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to cus...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to cus...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<br>","DataExportTag":"Q135","QuestionID":"QID135"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID320","SecondaryAttribute":"First though, take a moment to think about one of the most interesting lessons you have received....","TertiaryAttribute":null,"Payload":{"QuestionText":"First though, take a moment to think about  one of the <i>most interesting lessons <\/i>you have received. It could be from a class, a book, online.  Try to think of what the lesson said, and what you learned.<br><br>In this study, we will show you a lesson and then ask you questions like the following: \"How interesting is this information?\u201d&nbsp;If you were to answer this question for the <i>most interesting&nbsp;lesson you've ever received<\/i>&nbsp;you would mark \u201cExtremely.\u201d To confirm that you understand this instruction please click \u201cExtremely\u201d below:<br>","DefaultChoices":false,"DataExportTag":"Q320","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"First though, take a moment to think about one of the most interesting lessons you have received....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID320"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"Given this, please again take moment to reflect on how much you learned from first passage\u00a0you re..","TertiaryAttribute":null,"Payload":{"QuestionText":"Given this, please again take moment to reflect on how much you learned from <b>first passage&nbsp;<\/b>you read, overall. (Repeat: The first thing you read, <b>NOT<\/b> the above text.) You are welcome to respond in the same way or change your answers from before.","DefaultChoices":false,"DataExportTag":"Q68","QuestionID":"QID68","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Given this, please again take moment to reflect on how much you learned from first passage\u00a0you re...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID89","SecondaryAttribute":"Given this, please again take moment to reflect on how much you learned from the case you read, o...","TertiaryAttribute":null,"Payload":{"QuestionText":"Given this, please again take moment to reflect on how much you learned from <b>the case <\/b>you read, overall. (<b>The first thing you read, NOT the above text.<\/b>) You are welcome to respond in the same way or change your answers from before.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Given this, please again take moment to reflect on how much you learned from the case you read, o...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Now that you've had a moment to reflect on how much you learned beyond this summary, we'd like you to rerate the information. You are welcome to respond in the same way or change your answers from before.","DataExportTag":"Q89","QuestionID":"QID89"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID274","SecondaryAttribute":"Giving away your product to social media influencers can be an inexpensive but effective way of m...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>Giving away your product to social media influencers can be an inexpensive but effective way of marketing.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Giving away your product to social media influencers can be an inexpensive but effective way of m...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DataExportTag":"Q274","QuestionID":"QID274"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID190","SecondaryAttribute":"Here is all the information given by the business professor once more: The case: Dutch bicycle ma...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is all the information given by the business professor once more:<br><\/b><br><b>The case:<\/b><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br><br><b>The message: <\/b><br><i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is all the information given by the business professor once more: The case: Dutch bicycle ma...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Here is the real-world case again:<br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q190","QuestionID":"QID190"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID199","SecondaryAttribute":"Here is all the information given by the business professor once more: The message: Companies tha...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is all the information given by the business professor once more:<\/b><i><br><\/i><br><b>The message:<\/b><br><i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i><br><br><b>The case:<\/b><br><i>\n\nDutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is all the information given by the business professor once more: The message: Companies tha...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Here is the message again:<i><br><\/i><br>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<br>","DataExportTag":"Q199","QuestionID":"QID199"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID130","SecondaryAttribute":"Here is the case again: Dutch bicycle manufacturer VanMoof found that it had a problem. As it shi...","TertiaryAttribute":null,"Payload":{"QuestionText":"Here is the case again:<br><br>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br><br>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br><br>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<br>","DefaultChoices":false,"DataExportTag":"Q130","QuestionID":"QID130","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the case again: Dutch bicycle manufacturer VanMoof found that it had a problem. As it shi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID310","SecondaryAttribute":"Here is the message again: Being attuned to customer concerns during a major shift in company str...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br>\n<br>\n<i>Being attuned to customer concerns during a major shift in company structure can help ensure those customers are satisfied.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Being attuned to customer concerns during a major shift in company str...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the message again:<\/b><br \/>\n<br \/>\n<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DataExportTag":"Q310","QuestionID":"QID310"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID159","SecondaryAttribute":"Here is the message again: Companies that package their products in ways that superficially resem...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br>\n<br>\n<span style=\"color:#2980b9;\"><i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i><\/span>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Companies that package their products in ways that superficially resem...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Here is the real-world case again:<br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q159","QuestionID":"QID159"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID175","SecondaryAttribute":"Here is the message again: Companies that package their products in ways that superficially resem...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br \/>\n<br \/>\n<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Companies that package their products in ways that superficially resem...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Here is the message again:<i><br><\/i><br>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<br>","DataExportTag":"Q175","QuestionID":"QID175"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID265","SecondaryAttribute":"Here is the message again: Even if you have extremely compelling evidence, people often require t...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br>\n<br>\n<i>Even if you have extremely compelling evidence, people often require the support of an underlying theory before they will change their minds.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Even if you have extremely compelling evidence, people often require t...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the message again:<\/b><br \/>\n<br \/>\n<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DataExportTag":"Q265","QuestionID":"QID265"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID280","SecondaryAttribute":"Here is the message again: Giving away your product to social media influencers can be an inexpen...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br>\n<br>\n<i>Giving away your product to social media influencers can be an inexpensive but effective way of marketing.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Giving away your product to social media influencers can be an inexpen...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the message again:<\/b><br \/>\n<br \/>\n<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DataExportTag":"Q280","QuestionID":"QID280"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID295","SecondaryAttribute":"Here is the message again: Sometimes it can be lucrative for a company to improve the simplicity...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the message again:<\/b><br>\n<br>\n<i>Sometimes it can be lucrative for a company to improve the simplicity and speed of delivery rather than improve the product itself.<\/i>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the message again: Sometimes it can be lucrative for a company to improve the simplicity...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the message again:<\/b><br \/>\n<br \/>\n<i>Companies that package their products in ways that superficially resemble those of more fragile products can reduce damages due to shipping.<\/i>","DataExportTag":"Q295","QuestionID":"QID295"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"Here is the professor's\u00a0real-world case again: Dutch bicycle manufacturer VanMoof found that it h..","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the professor's&nbsp;real-world case again:<\/b><br>\n<br><i>\nDutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<br>\n<br>\nThe damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<br>\n<br>\nOne of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i>","DefaultChoices":false,"DataExportTag":"general","QuestionID":"QID67","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the professor's\u00a0real-world case again: Dutch bicycle manufacturer VanMoof found that it h...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID142","SecondaryAttribute":"Here is the real-world case again: In 1843, Dr. Semmelweis noticed a 3 to 1 imbalance in deaths d...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the real-world case again:<\/b><br><br><i>In 1843, Dr. Semmelweis noticed a 3 to 1 imbalance in deaths due to childbirth at one hospital compared to another. He performed experiments and was able to prove that the problem was that doctors in one hospital were not washing their hands. He then showed the hospital his data, but no one listened. It was only with the widespread adoption of germ theory (decades later), which supported his findings that all doctors began washing hands.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the real-world case again: In 1843, Dr. Semmelweis noticed a 3 to 1 imbalance in deaths d...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Here is the real-world case again:<br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q142","QuestionID":"QID142"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID250","SecondaryAttribute":"Here is the real-world case again: In 2008, Dominos was suffering from the Great Recession and th...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the real-world case again:<\/b><br><br><i>In 2008, Dominos was suffering from the Great Recession and the general consensus that their pizza was low quality. Instead of improving their pizza, they created a sales system that optimized ordering and delivery. Customers could customize their pizza online or through an app, and save their preferences. Because of this, from 2008 to 2020 their stock rose from $2.83 to $433.78.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the real-world case again: In 2008, Dominos was suffering from the Great Recession and th...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the real-world case again:<\/b><br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q250","QuestionID":"QID250"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID242","SecondaryAttribute":"Here is the real-world case again: In 2016, Jean-Philippe Courtois was put in charge of Microsoft...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the real-world case again:<\/b><br><br><i>In 2016, Jean-Philippe Courtois was put in charge of Microsoft\u2019s global sales and operations (over 40,000 people) as the company shifted to cloud based software. To best accommodate this change, Courtois decided to replace the company\u2019s training on anticipating customer questions with training on listening to customers, and scrapped lengthy performance reviews for coaching opportunities on interpersonal skills. Despite a huge transition to a cloud-based infrastructure, Microsoft saw a $19 million rise in revenue from 2016 to 2018 \u2013 mostly thanks to satisfied customers.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the real-world case again: In 2016, Jean-Philippe Courtois was put in charge of Microsoft...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the real-world case again:<\/b><br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q242","QuestionID":"QID242"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID234","SecondaryAttribute":"Here is the real-world case again: The Edwards family pooled $35,000 of their own money to produc...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Here is the real-world case again:<\/b><br><br><i>The Edwards family pooled $35,000 of their own money to produce their homeopathic cure for constipation: the Squatty Potty. With no money left to market the Potty, the family decided to simply give it away to various health media influencers on Instagram, Facebook, and Twitter. Despite spending no money on advertising, sales of the product quickly rose to $28,000, and caught the attention of Dr. Oz, Howard Stern, and Shark Tank, bringing Squatty Potty to an annual revenue of $12 million.<\/i><br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is the real-world case again: The Edwards family pooled $35,000 of their own money to produc...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<b>Here is the real-world case again:<\/b><br><br><i>Dutch bicycle manufacturer VanMoof found that it had a problem. As it shipped its products to customers, it found that many bicycles were arriving to customers damaged.<\/i><br><br><i>The damage reports were a major problem for the company because the company\u2019s bikes are high-end, and some are loaded down with delicate electronics like anti-theft trackers and electric motors. Plus, the company had set a goal to sell 90 percent of its bikes online by the end of the decade.<\/i><br><br><i>One of the employees came up with a solution: print a graphic of a flatscreen television on the side of the box. By making shippers think that they were transporting flatscreen televisions, the company found that shipping damage dropped by 70-80 percent. Nobody wants to damage a new television.<\/i><br>","DataExportTag":"Q234","QuestionID":"QID234"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID99","SecondaryAttribute":"How big is the takeaway for you?","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>How big is the takeaway for you?<\/i>","DefaultChoices":false,"DataExportTag":"t.g2","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How big is the takeaway for you?","Choices":{"2":{"Display":"Very small"},"3":{"Display":"Small"},"4":{"Display":"Somewhat small"},"5":{"Display":"Neither small nor big"},"7":{"Display":"Somewhat big"},"8":{"Display":"Big"},"9":{"Display":"Very big"}},"ChoiceOrder":["2","3","4","5","7","8","9"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"RecodeValues":{"2":"1","3":"2","4":"3","5":"4","7":"5","8":"6","9":"7"},"GradingData":[],"Language":[],"NextChoiceId":10,"NextAnswerId":3,"QuestionID":"QID99"}},{"SurveyID":"SV_6EI0MEnaSELekgS","Element":"SQ","PrimaryAttribute":"QID104","SecondaryAttribute":"How big is the takeaway for you?","TertiaryAttribute":null,"Payload":{"QuestionText":"<i>How big is the takeaway for you?<\/i>","DefaultChoices":false,"DataExportTag":"t.r","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How big is the takeaway for you?","Choices":{"2":{"Display":"Very small"},"3":{"Display":"Small"},"4":{"Display":"Somewhat small"},"5":{"Display":"Neither small nor big"},"7":{"Display":"Somewhat big"},"8":{"Display":"Big"},"9":{"Display":"Very big"}},"ChoiceOrder":["2","3","4","5","