urveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID1218493902","SecondaryAttribute":"This is a decision making quiz\u00a0for the RSM260 Class. Please be open and honest with your response..","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"color: rgb(0, 0, 0);\">This is a decision making quiz&nbsp;for the RSM260 Class. Please be open and honest with your responses. We will not share your specific answers with the class.&nbsp;<\/span><\/p><p><span style=\"color: rgb(0, 0, 0);\">&nbsp;<\/span><\/p><p><span style=\"color: rgb(0, 0, 0);\">Note: You will&nbsp;NOT be able to come back and finish it later. You should finish the whole quiz all at once.<\/span><\/p>","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This is a decision making quiz\u00a0for the RSM260 Class. Please be open and honest with your response...","GradingData":[],"Language":[],"DataVisibility":{"Private":false,"Hidden":false},"ChoiceOrder":[],"NextChoiceId":1,"NextAnswerId":1,"QuestionText_Unsafe":"<p><span style=\"color: rgb(0, 0, 0);\">This is a decision making quiz&nbsp;for the RSM260 Class. Please be open and honest with your responses. We will not share your specific answers with the class.&nbsp;<\/span><\/p><p><span style=\"color: rgb(0, 0, 0);\">&nbsp;<\/span><\/p><p><span style=\"color: rgb(0, 0, 0);\">Note: You will&nbsp;NOT be able to come back and finish it later. You should finish the whole quiz all at once.<\/span><\/p>","DataExportTag":"Q1","QuestionID":"QID1218493902"}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID1218493903","SecondaryAttribute":"What is your name? ","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your name?&nbsp;","DefaultChoices":false,"QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your name? ","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"What is your name?&nbsp;","DataExportTag":"name","QuestionID":"QID1218493903","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID18","SecondaryAttribute":"Question 1 When organizational cultures discourage dissent, what typically happens during critica...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 1<\/span><\/span><\/strong><br data-end=\"129\" data-start=\"126\" style=\"text-align:start\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">When organizational cultures discourage dissent, what typically happens during critical decision-making processes?<\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 1 When organizational cultures discourage dissent, what typically happens during critica...","Choices":{"1":{"Display":"A. Teams frequently pause to reconsider core assumptions."},"2":{"Display":"B. Individuals feel obligated to share doubts early and openly."},"3":{"Display":"C. Leaders seek out data that challenges group consensus."},"4":{"Display":"D. Teams inadvertently suppress information that could prevent failure."}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID18","RecodeValues":{"1":"0","2":"0","3":"0","4":"1"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"Question 2 Why might group consensus often obscure critical insights in evaluating risks?","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 2<\/span><\/span><\/strong><br style=\"text-align:start\" data-start=\"126\" data-end=\"129\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">Why might group consensus often obscure critical insights in evaluating risks? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 2 Why might group consensus often obscure critical insights in evaluating risks?","Choices":{"1":{"Display":"A. Group consensus guarantees that all relevant information is considered equally."},"2":{"Display":"B. Consensus-driven groups naturally highlight the most severe risks."},"3":{"Display":"C. Pressure to agree can prevent the thorough exploration of alternative interpretations and hidden threats."},"4":{"Display":"D. Groups tend to openly debate assumptions, reducing the risk of oversight."}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID19"}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"Question 2 When under pressure to deliver results, how do teams typically respond to ambiguous or...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 2<\/span><\/span><\/strong><br data-end=\"129\" data-start=\"126\" style=\"text-align:start\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">When under pressure to deliver results, how do teams typically respond to ambiguous or incomplete data about potential problems? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 2 When under pressure to deliver results, how do teams typically respond to ambiguous or...","Choices":{"1":{"Display":"A. They interpret uncertainty optimistically, assuming the best-case scenario."},"2":{"Display":"B. They delay projects indefinitely until data uncertainty is resolved."},"3":{"Display":"C. They actively seek disconfirming evidence to avoid bias."},"4":{"Display":"D. They share uncertainties transparently to prevent optimistic biases."}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID20","RecodeValues":{"1":"1","2":"0","3":"0","4":"0"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Question 4 Which organizational behavior increases the risk of overlooking critical problems duri...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 4<\/span><\/span><\/strong><br style=\"text-align:start\" data-start=\"126\" data-end=\"129\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">Which organizational behavior increases the risk of overlooking critical problems during decision-making? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q4","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 4 Which organizational behavior increases the risk of overlooking critical problems duri...","Choices":{"1":{"Display":"A. Encouraging multiple independent evaluations of the same data"},"2":{"Display":"B. Defining roles and responsibilities ahead of time"},"3":{"Display":"C. Normalizing previous successes as proof that risks are minimal"},"4":{"Display":"D. Regularly revisiting project assumptions through structured reflection"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID21"}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"Question 3 When decision-makers are faced with ambiguous or conflicting data, they tend to:","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 3<\/span><\/span><\/strong><br style=\"text-align:start\" data-start=\"126\" data-end=\"129\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">When decision-makers are faced with ambiguous or conflicting data, they tend to: <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 3 When decision-makers are faced with ambiguous or conflicting data, they tend to:","Choices":{"1":{"Display":"A. Give equal weight to both confirming and disconfirming information"},"2":{"Display":"B. Selectively interpret data to support a preferred conclusion."},"3":{"Display":"C. Automatically halt decision-making processes until clarity emerges."},"4":{"Display":"D. Delay their decision-making process"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID22","RecodeValues":{"1":"0","2":"1","3":"0","4":"0"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Question 6 When decision-makers are faced with ambiguous or conflicting data, they tend to:","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 6<\/span><\/span><\/strong><br data-end=\"129\" data-start=\"126\" style=\"text-align:start\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">When decision-makers are faced with ambiguous or conflicting data, they tend to: <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q6","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 6 When decision-makers are faced with ambiguous or conflicting data, they tend to:","Choices":{"1":{"Display":"A. Requiring thorough documentation of any identified risks"},"2":{"Display":"B. Creating a culture that punishes delay or hesitation"},"3":{"Display":"C. Assigning a dedicated individual to challenge assumptions during meetings"},"4":{"Display":"D. Training decision-makers in recognizing cognitive biases"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Question 4 Which of the following would most effectively help organizations avoid overconfidence...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 4<\/span><\/span><\/strong><br style=\"text-align:start\" data-start=\"126\" data-end=\"129\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">Which of the following would most effectively help organizations avoid overconfidence when facing ambiguous information? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q4","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 4 Which of the following would most effectively help organizations avoid overconfidence...","Choices":{"1":{"Display":"A. Reminding decision-makers regularly to carefully examine all available information"},"2":{"Display":"B. Clearly instructing teams to avoid rushing conclusions"},"3":{"Display":"C. Asking leaders explicitly to be more objective and unbiased"},"4":{"Display":"D. Establishing institutional practices that intentionally surface potential problems"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID24","RecodeValues":{"1":"0","2":"0","3":"0","4":"1"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"Question 5 Organizations frequently assume that having more data automatically reduces the likeli...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 5<\/span><\/span><\/strong><br style=\"text-align:start\" data-start=\"126\" data-end=\"129\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">Organizations frequently assume that having more data automatically reduces the likelihood of bad decisions. Why is this assumption problematic? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q5","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 5 Organizations frequently assume that having more data automatically reduces the likeli...","Choices":{"1":{"Display":"A. More data always leads to increased confusion rather than clarity."},"2":{"Display":"B. Decision-makers rarely have enough time to examine available data."},"3":{"Display":"C. Teams are more influenced by the culture around interpretation of data than by the quantity of data itself."},"4":{"Display":"D. Leaders typically ignore large amounts of data, regardless of its relevance."}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID25","RecodeValues":{"1":"0","2":"0","3":"1","4":"0"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"Question 6 An organization realizes it repeatedly makes flawed decisions due to groupthink. Which...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:medium\"><span style=\"line-height:normal\"><span style=\"font-family:Aptos, sans-serif\"><span style=\"color:#000000\"><span style=\"font-style:normal\"><span style=\"font-weight:400\"><span style=\"white-space:normal\"><span style=\"text-decoration:none\"><strong><span style=\"font-family:Garamond, serif\"><span style=\"color:black\">Question 6<\/span><\/span><\/strong><br data-end=\"129\" data-start=\"126\" style=\"text-align:start\">\n<span style=\"font-family:Garamond, serif\"><span style=\"color:black\"><span style=\"text-align:start; float:none\">An organization realizes it repeatedly makes flawed decisions due to groupthink. Which of the following actions would reduce the likelihood of groupthink in the future? <\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><\/span><br>","DefaultChoices":false,"DataExportTag":"Q6","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question 6 An organization realizes it repeatedly makes flawed decisions due to groupthink. Which...","Choices":{"1":{"Display":"A. Remind decision-makers to carefully examine all available data."},"2":{"Display":"B. Encourage team members to be cautious and skeptical when evaluating decisions."},"3":{"Display":"C. Explicitly instruct individuals to prioritize objectivity when interpreting ambiguous evidence."},"4":{"Display":"D. All of the above"},"5":{"Display":"E. None of the above"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID26","RecodeValues":{"1":"0","2":"0","3":"0","4":"0","5":"1"}}},{"SurveyID":"SV_1H0RZtEDx1vZ7b8","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}